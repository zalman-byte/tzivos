# ─── Twilio ────────────────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # Your Twilio phone number

# ─── Anthropic / Claude ────────────────────────────────────────────────────────
# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Maps ───────────────────────────────────────────────────────────────
# Enable "Geocoding API" at https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Staff Notifications ───────────────────────────────────────────────────────
STAFF_PHONE=+1XXXXXXXXXX          # SMS alerts go here
STAFF_EMAIL=coordinator@tzivos.org

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use an App Password: https://myaccount.google.com/apppasswords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your_app_password_here

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
